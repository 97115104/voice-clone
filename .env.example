# Voice Clone environment configuration
# Copy this file to .env and edit before exposing a public tunnel:
#   cp .env.example .env
#
# deploy-locally.sh creates .env automatically on first run if missing.

# Admin credentials (change password in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# JWT signing secret — change to a long random string in production
JWT_SECRET=voice-clone-change-me-in-production

# Chatterbox quality defaults (optional overrides)
# CB_EXAGGERATION=0.5
# CB_CFG_WEIGHT=0.5
# CB_TEMPERATURE=0.8

# Data directory inside the container (default: /app/data, mounted from ./data)
# DATA_DIR=/app/data
